# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/global-horizon-university
# For production use a cloud MongoDB instance:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/global-horizon-university

# Stripe API Keys (Replace with your own keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# PDF Certificate Settings
CERTIFICATE_STORAGE_PATH=src/server/certificates

# Security
JWT_SECRET=your_jwt_secret_for_auth_if_needed 